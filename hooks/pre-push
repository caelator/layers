#!/bin/sh
# Pre-push hook: clippy + fast unit tests + proveit status.
#
# Guards:
#   - Skips entirely when push to a remote (local-only ref updates are cheap)
#   - Skips when running from a bare repo (cargo requires a worktree)
#
# Usage: install via git config core.hooksPath=hooks (project-level, not .git/hooks)

# Detect bare repo — cargo commands require a worktree
if git rev-parse --is-inside-work-tree 2>/dev/null | grep -q "false"; then
    echo "[pre-push hook] SKIP: bare repository — cargo requires a worktree"
    exit 0
fi

# Only run on actual remote pushes, not local ref updates
# $1 = remote name, $2 = remote URL (empty for local)
remote_url="${2:-}"
if [ -z "$remote_url" ]; then
    echo "[pre-push hook] SKIP: local ref update (no remote push)"
    exit 0
fi

echo "Running pre-push checks..."

# Clippy — catches lints before push
echo "[pre-push] clippy..."
cargo clippy -- -D warnings
result=$?
if [ $result -ne 0 ]; then
    echo "Clippy failed. Fix warnings before pushing."
    exit 1
fi

# Unit tests — integration tests are feature-gated, so cargo test is safe.
echo "[pre-push] running unit tests..."
cargo test --lib --bins --tests
result=$?
if [ $result -ne 0 ]; then
    echo "Tests failed. Fix before pushing."
    exit 1
fi

# Proveit status — print stale/failing verdicts but never block.
echo "[pre-push] proveit status..."
cargo run --bin proveit -- status --warn-only 2>&1 || true

echo "Pre-push checks passed."
