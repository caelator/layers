#!/bin/sh
# Pre-commit hook: clippy with strict warnings.
#
# Guards:
#   - proveit_cli integration tests are skipped — they validate the proveit
#     binary in a full worktree with temp repos; covered by CI / worktree runs.
#
# Usage: install via git config core.hooksPath=hooks

echo "Running pre-commit clippy check..."
cargo clippy -- -D warnings
if [ $? -ne 0 ]; then
    echo "Clippy failed. Fix warnings before committing."
    exit 1
fi

echo "Running unit tests (skipping proveit_cli integration tests)..."
cargo test --lib --bins --tests 2>&1 | grep -v "^test proveit_cli"
if [ $? -ne 0 ]; then
    echo "Tests failed. Fix before committing."
    exit 1
fi

echo "Pre-commit checks passed."
